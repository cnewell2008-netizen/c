```

  </div>

  <!-- end message -->

  <div id="end-msg">
    <div class="end-title">Well done.</div>
    <div class="end-sub">you showed up for yourself</div>
    <button class="end-btn" id="again-btn">again</button>
    <button class="end-btn" id="done-btn">i'm ok now</button>
  </div>
</div>

<script>
  /* ── CONFIG ── */
  const PHASES = [
    { name: 'breathe in',  cls: 'breathing-in',  dur: 4 },
    { name: 'hold',        cls: 'holding',        dur: 4 },
    { name: 'breathe out', cls: 'breathing-out',  dur: 6 },
  ];
  const TOTAL_ROUNDS = 6;

  /* ── ELEMENTS ── */
  const landing    = document.getElementById('landing');
  const panicBtn   = document.getElementById('panic-btn');
  const session    = document.getElementById('session');
  const camVideo   = document.getElementById('cam-video');
  const camError   = document.getElementById('cam-error');
  const orbWrap    = document.getElementById('orb-wrap');
  const phaseLabel = document.getElementById('phase-label');
  const countDisp  = document.getElementById('count-display');
  const progFill   = document.getElementById('progress-fill');
  const progLabel  = document.getElementById('progress-label');
  const endMsg     = document.getElementById('end-msg');
  const closeBtn   = document.getElementById('close-btn');
  const againBtn   = document.getElementById('again-btn');
  const doneBtn    = document.getElementById('done-btn');

  /* ── STATE ── */
  let stream = null;
  let breathTimer = null;
  let currentPhase = 0;
  let currentRound = 0;
  let totalTicks = 0;
  let elapsedTicks = 0;

  /* total ticks across all rounds */
  const PHASE_TOTAL = PHASES.reduce((s, p) => s + p.dur, 0);
  const GRAND_TOTAL = PHASE_TOTAL * TOTAL_ROUNDS;

  /* ── LAUNCH ── */
  panicBtn.addEventListener('click', async () => {
    landing.classList.add('exit');
    setTimeout(() => { landing.style.display = 'none'; }, 800);
    session.classList.add('active');
    await startCamera();
    startBreathing();
  });

  /* ── CAMERA ── */
  async function startCamera() {
    try {
      stream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'user' }, audio: false });
      camVideo.srcObject = stream;
    } catch (e) {
      camError.classList.add('show');
    }
  }

  function stopCamera() {
    if (stream) { stream.getTracks().forEach(t => t.stop()); stream = null; }
  }

  /* ── BREATHING ENGINE ── */
  function startBreathing() {
    endMsg.classList.remove('visible');
    currentPhase = 0;
    currentRound = 0;
    elapsedTicks = 0;
    updateProgress();
    runPhase();
  }

  function runPhase() {
    clearTimeout(breathTimer);
    const phase = PHASES[currentPhase];

    // set orb class
    orbWrap.className = 'breath-orb-wrap';
    void orbWrap.offsetWidth; // reflow
    orbWrap.classList.add(phase.cls);

    phaseLabel.style.opacity = '0';
    setTimeout(() => {
      phaseLabel.textContent = phase.name;
      phaseLabel.style.opacity = '1';
    }, 250);

    countDisp.textContent = `round ${currentRound + 1} of ${TOTAL_ROUNDS}`;
    progLabel.textContent = phase.name;

    // tick down each second for progress
    let elapsed = 0;
    function tick() {
      elapsed++;
      elapsedTicks++;
      updateProgress();
      if (elapsed < phase.dur) {
        breathTimer = setTimeout(tick, 1000);
      } else {
        advance();
      }
    }
    breathTimer = setTimeout(tick, 1000);
  }

  function advance() {
    currentPhase++;
    if (currentPhase >= PHASES.length) {
      currentPhase = 0;
      currentRound++;
      if (currentRound >= TOTAL_ROUNDS) {
        finish();
        return;
      }
    }
    runPhase();
  }

  function finish() {
    orbWrap.className = 'breath-orb-wrap';
    phaseLabel.style.opacity = '0';
    progFill.style.width = '100%';
    progLabel.textContent = 'complete';
    setTimeout(() => { endMsg.classList.add('visible'); }, 600);
  }

  function updateProgress() {
    const pct = Math.min(100, (elapsedTicks / GRAND_TOTAL) * 100);
    progFill.style.width = pct + '%';
  }

  /* ── CLOSE / RESTART ── */
  closeBtn.addEventListener('click', () => reset(true));
  doneBtn.addEventListener('click', () => reset(true));
  againBtn.addEventListener('click', () => {
    endMsg.classList.remove('visible');
    startBreathing();
  });

  function reset(goHome) {
    clearTimeout(breathTimer);
    stopCamera();
    session.classList.remove('active');
    endMsg.classList.remove('visible');
    camError.classList.remove('show');
    orbWrap.className = 'breath-orb-wrap';
    if (goHome) {
      landing.style.display = '';
      landing.style.opacity = '0';
      landing.style.transform = 'scale(0.97)';
      landing.classList.remove('exit');
      setTimeout(() => {
        landing.style.transition = 'opacity 0.8s ease, transform 0.8s ease';
        landing.style.opacity = '1';
        landing.style.transform = 'scale(1)';
      }, 50);
    }
  }
</script>

</body>
</html>
