<div class="phase-label" id="phase-label">breathe in</div>

<div class="breath-orb-wrap" id="orb-wrap">
  <div class="orb-ring r3"></div>
  <div class="orb-ring r2"></div>
  <div class="orb-ring"></div>
  <div class="orb-core"></div>
</div>

<div class="count-display" id="count-display">round 1 of 6</div>

<div class="progress-wrap">
  <div class="progress-track">
